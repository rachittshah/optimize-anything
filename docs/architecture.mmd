flowchart TB
    subgraph USER["User / Claude Code"]
        A["Seed Candidate<br/>(prompt, code, config)"]
        B["Evaluator Config<br/>(Python / Shell / LLM Judge)"]
        C["Objective<br/>(natural language goal)"]
    end

    subgraph ENGINE["Python Optimization Engine"]
        D["Initialize State<br/>+ Pareto Frontier"]
        E["SELECT parent<br/>from frontier"]
        F["SAMPLE minibatch<br/>from dataset"]
        G["EVALUATE parent<br/>→ score + ASI"]
        H["REFLECT on ASI<br/>+ build prompt"]
        I["PROPOSE improvement<br/>via Claude API"]
        J["EVALUATE new<br/>candidate"]
        K{"Better than<br/>parent?"}
        L["UPDATE Pareto<br/>frontier"]
        M{"Budget<br/>exhausted?"}
        N["CHECKPOINT<br/>to disk"]
        O["Return best<br/>candidate + history"]
    end

    subgraph EVALUATORS["Evaluator Types"]
        P["Python Evaluator<br/>(subprocess)"]
        Q["Shell Evaluator<br/>(command + regex)"]
        R["LLM Judge<br/>(Claude Sonnet)"]
    end

    subgraph MCP["TypeScript MCP Server"]
        S["optimize_anything"]
        T["check_optimization"]
        U["get_best_candidate"]
        V["stop_optimization"]
        W["list_optimization_runs"]
    end

    A --> D
    B --> D
    C --> D
    D --> E
    E --> F
    F --> G
    G --> H
    H --> I
    I --> J
    J --> K
    K -->|Yes| L
    K -->|No| M
    L --> M
    M -->|No| E
    M -->|Yes| O
    E -.->|every N iters| N

    G --> P & Q & R
    J --> P & Q & R

    S -->|spawns| D
    T -->|reads| N
    U -->|reads| O
    V -->|kills| ENGINE
    W -->|lists| N

